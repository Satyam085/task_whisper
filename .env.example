# Telegram
TELEGRAM_TOKEN=
ALLOWED_USER_ID=
CHAT_ID=

# Gemini
GEMINI_API_KEY=

# Google Tasks List IDs (get these from: go run scripts/get_list_ids.go)
GTASKS_LIST_PERSONAL=
GTASKS_LIST_OFFICE=
GTASKS_LIST_SHOPPING=
GTASKS_LIST_OTHERS=

# Google Auth files
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# App config
PORT=8080
WEBHOOK_URL=
AUTO_REGISTER_WEBHOOK=true
TIMEZONE=Asia/Kolkata
SUMMARY_TIME=08:00

# Optional
SQLITE_PATH=./tasks.db
LOG_LEVEL=info
